# ==================================
# Beholder - Archivo de ejemplo .env
# ==================================
# Este archivo usa datos mock. NO colocar credenciales reales aquí.

# Clave usada por el backend para autorizar requests entrantes
API_KEY=mock_api_key_123456

# Ruta local de la base SQLite (cache/estado interno)
DB_PATH=data/diag.db

# ----------------------------------
# SmartOLT
# ----------------------------------
# URL base de la API de SmartOLT
SMARTOLT_BASEURL=https://smartolt.mock.local/api
# Token API de SmartOLT
SMARTOLT_TOKEN=mock_smartolt_token

# ----------------------------------
# Mikrotik (router por defecto)
# ----------------------------------
# IP o hostname del Mikrotik default
MK_HOST=10.99.0.1
# Usuario API/CLI
MK_USER=mock_mk_user
# Password API/CLI
MK_PASS=mock_mk_password
# Puerto API (8728/8729 o custom según red)
MK_PORT=8728

# ----------------------------------
# GenieACS (opcional según despliegue)
# ----------------------------------
GENIEACS_URL=http://127.0.0.1:7547

# ----------------------------------
# ISPCube
# ----------------------------------
ISPCUBE_BASEURL=https://api.mock.ispcube.local
ISPCUBE_APIKEY=mock_ispcube_apikey
ISPCUBE_USER=mock_ispcube_user
ISPCUBE_PASSWORD=mock_ispcube_password
ISPCUBE_CLIENTID=mock_ispcube_client_id

# ----------------------------------
# Oráculo - InfluxDB (principal)
# ----------------------------------
# Endpoint HTTP de InfluxDB (v2)
ORACULO_INFLUX_URL=http://127.0.0.1:8086
# Token de acceso
ORACULO_INFLUX_TOKEN=mock_influx_token
# Organización Influx
ORACULO_INFLUX_ORG=mock_org
# Bucket general (compatibilidad/fallback)
ORACULO_INFLUX_BUCKET=netflow
# Timeout de lectura/consulta en milisegundos
ORACULO_INFLUX_TIMEOUT_MS=10000
# Reintentos para integraciones externas (Influx/Graylog)
ORACULO_RETRY_ATTEMPTS=3
ORACULO_RETRY_BACKOFF_SEC=1.0
ORACULO_RETRY_BACKOFF_MULTIPLIER=2.0

# Oráculo - InfluxDB (downsampling)
# Bucket de datos crudos (tiempo real)
ORACULO_INFLUX_RAW_BUCKET=netflow
# Bucket de datos resumidos (histórico)
ORACULO_INFLUX_RESUMEN_BUCKET=netflow_resumen
# Measurement en bucket crudo
ORACULO_INFLUX_RAW_MEASUREMENT=netflow
# Measurement en bucket resumido
ORACULO_INFLUX_RESUMEN_MEASUREMENT=resumen_5m
# Field de bytes entrantes sobre el que se calcula Mbps
ORACULO_INFLUX_IN_BYTES_FIELD=in_bytes
# Tag de IP cliente dentro del bucket resumido
ORACULO_INFLUX_RESUMEN_IP_TAG=ip_cliente
# Tag usado por Influx para identificar el nodo
ORACULO_INFLUX_NODE_TAG=source
# Tag que indica sentido de tráfico (descarga/subida)
ORACULO_INFLUX_RESUMEN_SENTIDO_TAG=sentido
# Valores del tag de sentido
ORACULO_INFLUX_SENTIDO_DESCARGA=descarga
ORACULO_INFLUX_SENTIDO_SUBIDA=subida
# Duración en segundos de cada bloque para convertir bytes a Mbps
ORACULO_INFLUX_REALTIME_WINDOW_SECONDS=60
ORACULO_INFLUX_RESUMEN_WINDOW_SECONDS=300

# ----------------------------------
# Oráculo - Graylog
# ----------------------------------
# URL base de Graylog (sin /api al final)
ORACULO_GRAYLOG_URL=http://127.0.0.1:9000
# Usuario de API (o token si usan token auth)
ORACULO_GRAYLOG_USER=mock_graylog_user
# Password de API (o literal 'token' en token auth)
ORACULO_GRAYLOG_PASSWORD=mock_graylog_password
# Timeout HTTP a Graylog en segundos
ORACULO_GRAYLOG_TIMEOUT_SEC=15
# Ventana de búsqueda en segundos (30 días por defecto)
ORACULO_GRAYLOG_RANGE_SEC=2592000
# Orden de resultados Graylog
ORACULO_GRAYLOG_SORT=timestamp:asc
# Campos solicitados a Graylog (algunas versiones lo requieren)
ORACULO_GRAYLOG_FIELDS=message,source,timestamp
# Mapeo de nodo externo -> nodo interno de Influx
ORACULO_NODO_IP_MAP=203.0.113.6=10.255.255.2;203.0.113.7=10.255.255.3;203.0.113.8=10.255.255.4;203.0.113.9=10.255.255.5